# ---- Profiles (Cloud Accountant Staffing) env template ----
# Copy to .env and fill in. Never commit .env.

# Postgres (dockerized; own DB)
POSTGRES_DB=profiles
POSTGRES_USER=profiles
POSTGRES_PASSWORD=change-me-dev-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Clerk auth — from the Clerk dashboard (https://dashboard.clerk.com)
# Frontend (Next.js) needs the publishable key; backend verifies via JWKS/issuer.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Issuer = your Clerk Frontend API URL, e.g. https://your-app.clerk.accounts.dev
CLERK_ISSUER=
# JWKS URL (usually <CLERK_ISSUER>/.well-known/jwks.json)
CLERK_JWKS_URL=

# Booking
NEXT_PUBLIC_CALENDLY_URL=

# Media storage (VPS-local for now). Later: swap to R2/Bunny via storage backend.
MEDIA_ROOT=/app/media
STORAGE_BACKEND=local

# Assess deep-link base (for personality type)
ASSESS_BASE_URL=https://assess.wetreadwell.com
